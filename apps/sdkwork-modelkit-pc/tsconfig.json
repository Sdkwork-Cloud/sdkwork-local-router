{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@sdkwork/modelkit-sdk-typescript": [
        "./sdks/sdkwork-modelkit-sdk-typescript/src/index.ts",
        "./sdks/sdkwork-modelkit-sdk-typescript/src"
      ],
      "@sdkwork/modelkit-*": [
        "./packages/sdkwork-modelkit-*/src/index.ts",
        "./packages/sdkwork-modelkit-*/src"
      ],
      "@/*": [
        "./*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}
