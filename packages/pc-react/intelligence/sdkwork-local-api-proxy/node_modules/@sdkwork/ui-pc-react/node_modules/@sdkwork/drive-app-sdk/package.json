{
  "name": "@sdkwork/drive-app-sdk",
  "version": "0.1.0",
  "description": "SDKWork Drive App SDK with high-level uploader facade.",
  "type": "module",
  "private": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "composed",
    "generated/server-openapi/dist",
    "generated/server-openapi/src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./uploader": {
      "types": "./composed/uploader/index.ts",
      "import": "./composed/uploader/index.ts",
      "default": "./composed/uploader/index.ts"
    },
    "./generated": {
      "types": "./generated/server-openapi/src/index.ts",
      "import": "./generated/server-openapi/src/index.ts",
      "default": "./generated/server-openapi/src/index.ts"
    }
  },
  "dependencies": {
    "@sdkwork/sdk-common": "^1.0.3"
  },
  "peerDependencies": {
    "@sdkwork/appbase-app-sdk": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@sdkwork/appbase-app-sdk": {
      "optional": true
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  },
  "keywords": [
    "sdkwork",
    "drive",
    "app-sdk",
    "upload"
  ]
}
