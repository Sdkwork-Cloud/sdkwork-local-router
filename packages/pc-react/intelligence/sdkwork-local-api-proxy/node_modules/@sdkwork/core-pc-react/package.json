{
  "name": "@sdkwork/core-pc-react",
  "version": "0.1.1",
  "description": "Unified SDKWork core runtime for Tauri React desktop apps",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.cjs",
      "default": "./src/index.ts"
    },
    "./app": {
      "types": "./src/app/index.ts",
      "import": "./src/app/index.ts",
      "default": "./src/app/index.ts"
    },
    "./env": {
      "types": "./src/env/index.ts",
      "import": "./src/env/index.ts",
      "default": "./src/env/index.ts"
    },
    "./hooks": {
      "types": "./src/hooks/index.ts",
      "import": "./src/hooks/index.ts",
      "default": "./src/hooks/index.ts"
    },
    "./im": {
      "types": "./src/im/index.ts",
      "import": "./src/im/index.ts",
      "default": "./src/im/index.ts"
    },
    "./preferences": {
      "types": "./src/preferences/index.ts",
      "import": "./src/preferences/index.ts",
      "default": "./src/preferences/index.ts"
    },
    "./runtime": {
      "types": "./src/runtime/index.ts",
      "import": "./src/runtime/index.ts",
      "default": "./src/runtime/index.ts"
    }
  },
  "scripts": {
    "check:boundary": "node ./scripts/check-package-boundary.mjs",
    "build:deps": "pnpm --filter @sdkwork/sdk-common build",
    "build": "pnpm run build:deps && vite build",
    "test": "vitest run",
    "typecheck": "pnpm run build:deps && tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "dependencies": {
    "@sdkwork/sdk-common": "^1.0.3"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "^29.0.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "8.0.3",
    "vite-plugin-dts": "catalog:",
    "vitest": "^4.1.2"
  }
}
