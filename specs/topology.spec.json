{
  "schemaVersion": 5,
  "kind": "sdkwork.app.topology",
  "appId": "sdkwork-local-router",
  "archetype": "application-http-gateway",
  "profileRoot": "etc/topology",
  "profilePattern": "{deploymentProfile}.{environment}.env",
  "vocabulary": {
    "deploymentProfile": {
      "allowed": [
        "standalone",
        "cloud"
      ]
    },
    "environment": {
      "allowed": [
        "development",
        "production"
      ]
    },
    "connectivityPlane": {
      "allowed": [
        "application",
        "platform"
      ]
    }
  },
  "defaults": {
    "developmentProfileId": "standalone.development",
    "productionProfileId": "cloud.production",
    "desktopBuildProfileId": "standalone.production",
    "gatewayBind": "127.0.0.1:8080"
  },
  "profileFiles": {
    "standalone.development": "etc/topology/standalone.development.env",
    "standalone.production": "etc/topology/standalone.production.env",
    "cloud.development": "etc/topology/cloud.development.env",
    "cloud.production": "etc/topology/cloud.production.env"
  },
  "envKeys": {
    "deploymentProfile": "SDKWORK_LOCAL_ROUTER_DEPLOYMENT_PROFILE",
    "environment": "SDKWORK_LOCAL_ROUTER_ENVIRONMENT",
    "profileId": "SDKWORK_LOCAL_ROUTER_PROFILE_ID",
    "clientDeploymentProfile": "VITE_SDKWORK_LOCAL_ROUTER_DEPLOYMENT_PROFILE",
    "standaloneGatewayBind": "SDKWORK_LOCAL_ROUTER_APPLICATION_PUBLIC_INGRESS_BIND",
    "apiGatewayBaseUrl": "SDKWORK_LOCAL_ROUTER_PLATFORM_API_GATEWAY_HTTP_URL",
    "clientApiGatewayBaseUrl": "VITE_SDKWORK_LOCAL_ROUTER_PLATFORM_API_GATEWAY_HTTP_URL"
  },
  "surfaces": {
    "application.public-ingress": {
      "connectivityPlane": "application",
      "protocols": [
        "http"
      ],
      "bindEnv": "SDKWORK_LOCAL_ROUTER_APPLICATION_PUBLIC_INGRESS_BIND",
      "httpUrlEnv": "SDKWORK_LOCAL_ROUTER_APPLICATION_PUBLIC_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_LOCAL_ROUTER_APPLICATION_PUBLIC_HTTP_URL"
    },
    "platform.api-gateway": {
      "connectivityPlane": "platform",
      "protocols": [
        "http"
      ],
      "httpUrlEnv": "SDKWORK_LOCAL_ROUTER_PLATFORM_API_GATEWAY_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_LOCAL_ROUTER_PLATFORM_API_GATEWAY_HTTP_URL"
    }
  },
  "cloudPublicHosts": {
    "application.public-ingress": {
      "httpHost": "api.sdkwork.com",
      "httpPath": "/apps/sdkwork-local-router"
    },
    "platform.api-gateway": {
      "httpHost": "api.sdkwork.com"
    }
  },
  "database": {
    "appPrefix": "SDKWORK_LOCAL_ROUTER"
  },
  "components": {
    "applicationServer": {
      "crate": "sdkwork-local-router",
      "binary": "lr"
    }
  },
  "orchestration": {
    "profiles": {
      "standalone.development": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-local-router",
            "binary": "lr",
            "required": true,
            "role": "api-standalone-gateway"
          }
        ],
        "healthSurfaces": [
          "application.public-ingress"
        ]
      },
      "standalone.production": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-local-router",
            "binary": "lr",
            "required": true,
            "role": "api-standalone-gateway"
          }
        ],
        "healthSurfaces": [
          "application.public-ingress"
        ]
      },
      "cloud.development": {
        "processes": [],
        "healthSurfaces": [
          "application.public-ingress",
          "platform.api-gateway"
        ]
      },
      "cloud.production": {
        "processes": [],
        "healthSurfaces": [
          "application.public-ingress",
          "platform.api-gateway"
        ]
      }
    }
  },
  "packaging": {
    "targets": [],
    "cloudConfigFiles": []
  }
}
