{
  "schemaVersion": 1,
  "kind": "sdkwork.route.manifest",
  "packageName": "sdkwork-routes-local-router-open-api",
  "surface": "open-api",
  "owner": "sdkwork-local-router",
  "domain": "intelligence",
  "capability": "local-router",
  "apiAuthority": "sdkwork-local-router-open-api",
  "sdkFamily": "sdkwork-local-router-sdk",
  "prefix": "/local-router",
  "routes": [
    {
      "method": "ANY",
      "path": "/local-router/v1/{*path}",
      "operationId": "localRouter.openai.proxy",
      "requestContext": "WebRequestContext",
      "apiSurface": "open-api",
      "auth": {
        "mode": "api-key"
      },
      "externalProtocolId": "openai"
    },
    {
      "method": "ANY",
      "path": "/local-router/anthropic/{*path}",
      "operationId": "localRouter.anthropic.proxy",
      "requestContext": "WebRequestContext",
      "apiSurface": "open-api",
      "auth": {
        "mode": "api-key"
      },
      "externalProtocolId": "anthropic"
    },
    {
      "method": "ANY",
      "path": "/local-router/google/{*path}",
      "operationId": "localRouter.google.proxy",
      "requestContext": "WebRequestContext",
      "apiSurface": "open-api",
      "auth": {
        "mode": "api-key"
      },
      "externalProtocolId": "google"
    }
  ]
}
